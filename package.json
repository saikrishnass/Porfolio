{
  "name": "mern-portfolio",
  "version": "1.0.0",
  "description": "Premium Motion Portfolio - MERN Stack",
  "main": "server.js",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend --legacy-peer-deps",
    "backend": "npm start --prefix backend",
    "backend-dev": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend-dev\" \"npm run frontend\"",
    "seed": "npm run seed --prefix backend"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
